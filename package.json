{
  "name": "@vilius/web-scraper",
  "version": "1.0.0",
  "description": "Advanced web scraper for email discovery with multiple data sources (web pages, GitHub)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node examples/basic-usage.ts",
    "example": "ts-node examples/cli.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "web-scraper",
    "email-finder",
    "email-extractor",
    "github-scraper",
    "data-extraction",
    "puppeteer",
    "cheerio"
  ],
  "author": "Vilius Brazdeikis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/web-scraper.git"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "puppeteer": "^23.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
